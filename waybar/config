[{
    "height": 40,
    "spacing": 5,  

    // "height": 40,
    // "spacing": 5,

    "modules-left": [
        "group/Utilities",
        "group/workspaces",
        "group/network"
    ],
    "modules-center": [
        "group/windows"
    ],
    "modules-right": [
        "group/cpuram",
        "group/system"
    ],

    "custom/openbracket": {
        "format": "[",
        "tooltip": false
    },
    "custom/closebracket": {
        "format": "]",
        "tooltip": false
    },    
    "custom/split": {
      "format": "|",
      "tooltip": false
    },

    "group/Utilities":{
        "orientation": "horizontal",
        "modules":[
            "custom/openbracket",
            "custom/arch",
            "custom/closebracket"
        ]
    },

    "group/power": {
        "orientation": "horizontal",
        "modules": [
            "custom/openbracket",
            "custom/power",
            "custom/closebracket"
        ]
    },

    "custom/power": {
	"format": "έΠ╗",
        //"on-click": "$HOME/.config/hypr/scripts/Wlogout.sh",
        "on-click": "wlogout",
        //"on-click-right": "$HOME/.config/hypr/scripts/ChangeBlur.sh",
        "tooltip": true,
        "tooltip-format": "Left Click: Logout Menu",
    },

    "custom/arch": {
         "format": "≤░μΘ",
        "tooltip": false,
         "on-click": "wofi --show drun"
    },
    "custom/powerprofile": {
        "exec": "~/.config/waybar/scripts/powerprofile.sh display",
        "on-click": "~/.config/waybar/scripts/powerprofile.sh toggle",
        "interval": 5,
        "tooltip": true,
        "exec-tooltip": "~/.config/waybar/scripts/powerprofile.sh tooltip",
        "tooltip-format": "Power Profile: {} \nClick to cycle: Efficient έΗΤ Normal έΗΤ Overclocked"
    },
    
    "group/workspaces":{
        "orientation": "horizontal",
        "modules":[
            "custom/openbracket",
            "hyprland/workspaces",
            "custom/closebracket"
        ]
    },
    "hyprland/workspaces": {
        "all-outputs": true,
        "warp-on-scroll": false,
        "enable-bar-scroll": true,
        "disable-scroll-wraparound": true,
        "active-only": false,
        "format": "{icon}",
        "format-icons": {
            "1": "ϊ╕Α", 
            "2": "ϊ║Ν",
            "3": "ϊ╕Κ",
            "4": "ίδδ",
            "5": "ϊ║Φ",
            "6": "ίΖφ",
            "default": "έΑλ"
        }
    },

    "mpris": {
        "format": "[ ΎΑΒ  {status_icon} | {dynamic} ]",
        "interval": 1,
        "dynamic-len": 40,
        "player-icons": {
            "chromium": "ΎΚρ",
            "default": "ΎΑζ",
            "firefox": "ΎΚσ",
            "kdeconnect": "",
            "mopidy": "ΎΑΒ",
            "mpv": "≤░Ρ╣",
            "spotify": "ΎΗ╝",
            "vlc": "≤░Χ╝",
	    },
        "status-icons": {
            "playing": "έΨ╢",
            "paused": "έΠ╕",
            "stopped": "ΎΒΞ"
        },
        "dynamic-order": ["artist"]
    },

    "power-profiles-daemon": {
        "format": " {icon} ",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "ΎΔπ",
            "performance": "≤░ΥΖ",
            "balanced": "≤░╛Ζ",
            "power-saver": "≤░╛Η"
        }
    },

    "group/windows": {
        "orientation":"horizontal",
        "modules":[
            "custom/openbracket",
            "hyprland/window",
            "custom/closebracket"
        ]
    },
    "hyprland/window": {
        "format": "{title}", 
        "max-length": 28,
        "min-length": 0,
        "all-outputs": true
    },

    "group/cpuram": {
        "orientation": "horizontal",
        "modules": [
            "custom/openbracket",
            "cpu",
            "custom/split",
            "memory",
            "custom/closebracket"
        ]
    },
    "cpu": {
        "format": "CPU:{usage}%",
        "tooltip": false,
        "interval": 2,
        "on-click": "kitty -e btop",
    },
    "memory":{
        "format": "RAM:{}%",
        "tooltip": false,
        "interval": 2,
        "on-click": "kitty -e btop",
    },

    "group/brightvol": {
        "orientation": "horizontal",
        "modules": [
            "custom/openbracket",
            "backlight",
            "custom/split",
            "wireplumber",
            "custom/closebracket"
        ]
    },
    "wireplumber": {
        "scroll-step": 5,
        "format": "{icon}{volume}%",
        "format-bluetooth": "{icon}{volume}% ΎΛΦ",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ",
        "format-muted": "Ύγσ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο :", "ΎΑπ :", "ΎΑρ :"]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol"
    },

    "pulseaudio": {
        "format": " {icon}  ",
        "format-bluetooth": "{icon} ",
        "format-muted": " ≤░ΨΒ  ",
        "format-icons": {
            "headphone": [
                "ΎΑο", "ΎΑπ", "≤░Χ╛",  "ΎΑρ"
            ],
            "hands-free": "ΎΑξ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": [
                "ΎΑο", "ΎΑπ", "≤░Χ╛",  "ΎΑρ"
            ],
            "ignored-sinks": [
                "Easy Effects Sink"
            ],
        },
        "scroll-step": 5.0,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "$HOME/.config/hypr/scripts/Volume.sh --inc",
        "on-scroll-down": "$HOME/.config/hypr/scripts/Volume.sh --dec",
        "tooltip-format": "{icon} {desc} | {volume}%",
        "smooth-scrolling-threshold": 1,
    },
    "backlight": {
        "format": "{icon}:{percent}%",
        "format-icons": ["ΎΗΖ", "ΎΕΣ", "ΏθΝβ"],
        "on-click": "~/.config/waybar/scripts/brightness_slider.sh"  
    },

    "group/system": {
        "orientation": "horizontal",
        "modules": [
            "custom/openbracket",
            "custom/swaync",
            "custom/keyboard",
            "custom/split",
            "clock",
            "custom/split",
            //"network",
            "pulseaudio",
            "bluetooth",
            //"custom/clipboard",
            "power-profiles-daemon",
            "battery",
            "custom/battery_notify",
            "custom/closebracket"
        ]
    },
    "clock": {
        "format": "{:%H:%M}", // 24H ΎΑΩ
        "format-alt": "{:%a%e %b}", //ΎΒ│
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "onclick" : "kalender",
        "on-click-right": "~/.config/waybar/scripts/timer.sh"
    },
    "custom/clipboard": {
        "format": "ΎΔς",
        "tooltip": false,
        "on-click": "~/.config/waybar/scripts/clipboard_menu.sh"
    },
    "battery": {
        "states": {
            "warning": 15,
            "critical": 5
        },
        "format": "{icon} {capacity}%",
        "format-full": "{icon} {capacity}%",
        "format-charging": "ΎΔπ {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "on-click": "wlogout",
        "interval": 10
    },
    "custom/battery_notify": {
        "exec": "~/.config/waybar/scripts/bateria_notify.sh",
        "interval": 30,
        "return-type": "json"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "custom/swaync": {
        "tooltip": true,
        "tooltip-format": "Left Click: Launch Notification Center\nRight Click: Do not Disturb",
        "format": "{}{icon}",
        "format-icons": {
            "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "none": "ΎΓλ",
            "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "dnd-none": "ΎΘ╖",
            "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "inhibited-none": "ΎΓλ",
            "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
            "dnd-inhibited-none": "ΎΘ╖"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "sleep 0.1 && swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true,
    },
    "custom/keyboard": {
        "exec": "$HOME/.config/waybar/scripts/SwitchKeyboardLayout.sh --print",
        "interval": 1,
        "format": " ΎΕε {} ",
        "on-click": "$HOME/.config/waybar/scripts/SwitchKeyboardLayout.sh --toggle",
        "tooltip": true,
        "tooltip-format": "{}",
    },


    "group/network": {
        "orientation": "horizontal",
        "modules": [
            "custom/openbracket",
            "network",
            "network#vpn",
            "custom/closebracket"
        ]
    },


    "network": {
        "format": "{ifname}",
        "format-wifi": "{icon} {ipaddr}",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "ΌτΡ",
        "tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBits} ΎΕ║ {bandwidthDownBits}",
        "format-linked": "≤░ΙΒ {ifname} (No IP)",
        "tooltip-format-wifi": "{ifname} {essid} {signalStrength}%",
        "tooltip-format-ethernet": "{ifname} ≤░Να",
        "tooltip-format-disconnected": "≤░Νβ Disconnected",
        "max-length": 30,
        "format-icons": [
            "≤░νψ", "≤░νθ", "≤░νλ", "≤░νρ", "≤░νρ"
        ],
        "on-click": "kitty --class=nmtui -e nmtui",
        "on-click-right": "$HOME/.config/waybar/scripts/routerconfiguration.sh"       
    },

    "bluetooth": {
        "format": "ΎΛΥ ",
        "format-disabled": "≤░Γ│ ",
        "format-connected": "≤░Γ▒ ",
        "tooltip-format": "ΎΛΥ {device_alias}",
        "tooltip-format-connected": "{device_enumerate}",
        "tooltip-format-enumerate-connected": "ΎΛΥ {device_alias} ≤░ΓΕ{device_battery_percentage}%",
        "tooltip": true,
        "on-click": "blueman-manager"
    },
    "network#vpn": {
        "interface": "tun0",
        "format": "≤▒ΓΘ {ipaddr}",
        "format-wifi": "≤▒ΓΘ {ipaddr}",
        "format-ethernet": "≤▒ΓΘ {ipaddr}",
        "format-disconnected": "", //An empty format will hide the module.
        "tooltip-format": "{ifname} {essid} {gwaddr} ({signalStrength}%) ΎΘτ",
        "tooltip-format-wifi": "{ifname} {essid} {gwaddr} ({signalStrength}%) ΎΘτ",
        "tooltip-format-ethernet": "{ifname} {essid} {gwaddr} ({signalStrength}%) ΎΘτ",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50
    },
    "group/clock": {
        "orientation": "horizontal",
        "modules": [
            "custom/openbracket",
            "clock",
            "custom/closebracket"
        ]
    },
    "custom/cava": {
        "exec": "~/.config/waybar/scripts/cava_wrapper.sh",
        "format": "έβς {}",
        "restart-interval": 1,
        "max-length": 50,
        "on-click": "pkill cava"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 10
    }
}]
